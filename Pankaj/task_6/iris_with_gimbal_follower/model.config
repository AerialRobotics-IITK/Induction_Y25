<?xml version="1.0"?>
<model>
  <name>Iris with Gimbal Follower</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>ARIITK Task 6</name>
  </author>
  <description>
    Patched copy of iris_with_gimbal for iris_2 (follower drone).
    Only change from stock: fdm_port_in changed from 9002 to 9012
    so it connects to ArduPilot SITL instance 1.
    All gimbal joints, camera, and lift-drag plugins are identical
    to the original iris_with_gimbal model.
    This model lives inside task_6/ so no system files need editing.
  </description>
  <depend>
    <model>
      <uri>model://gimbal_small_3d</uri>
      <version>2.0</version>
    </model>
    <model>
      <uri>model://iris_with_standoffs</uri>
      <version>2.0</version>
    </model>
  </depend>
</model>
